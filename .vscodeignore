# Keep the .vsix small — ship only what runs. node_modules is bundled by vsce because
# the SDK (and its per-platform claude binary) must ship; don't ignore it.
.gitignore
.vscode/**
PLAN.md
**/*.map
# Planning system + vendored reference — never ship these in the .vsix
planning/**
reference/**
test/**
scripts/**
PROGRESS.md
SESSION_PROMPT.md
OWNER_TODO.md
CLAUDE.md
.github/**
*.vsix
